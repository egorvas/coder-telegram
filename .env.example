# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Coder API base URL (no trailing slash)
CODER_API_URL=

# Polling interval in ms (optional, default 15000)
# POLL_INTERVAL_MS=15000

# Admin users — can access the bot and manage other users via admin panel
# If set, only admins and users added via admin panel can use the bot
# If unset, the bot is open to everyone
# ADMIN_USERS=123456789

# Log level: debug | info | warn | error (optional, default info)
# LOG_LEVEL=info
