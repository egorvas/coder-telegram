# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Coder API base URL (no trailing slash)
CODER_API_URL=

# Polling interval in ms (optional, default 15000)
# POLL_INTERVAL_MS=15000

# Access control — comma-separated Telegram user IDs allowed to use the bot
# Leave unset to allow all users (not recommended for production)
# ALLOWED_USERS=123456789,987654321

# Admin users — can manage the user list and toggle all-users view
# ADMIN_USERS=123456789
